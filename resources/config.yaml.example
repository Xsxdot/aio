# AI 服务配置示例
ai:
  # 供应商配置
  providers:
    # OpenAI 兼容供应商（通义千问兼容模式）
    - name: dashscope_compat
      type: openai_compat
      base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
      api_key: ${DASHSCOPE_API_KEY}
      timeout: 30

    # DashScope 原生供应商（异步任务、WebSocket）
    - name: dashscope
      type: dashscope
      base_url: https://dashscope.aliyuncs.com
      api_key: ${DASHSCOPE_API_KEY}
      timeout: 30

    # OpenAI 供应商（可选）
    - name: openai
      type: openai_compat
      base_url: https://api.openai.com/v1
      api_key: ${OPENAI_API_KEY}
      organization: ${OPENAI_ORG_ID}
      timeout: 30

  # 路由器配置
  router:
    # 精确模型映射
    model_mappings:
      gpt-4: openai
      gpt-3.5-turbo: openai
      qwen3-vl-plus: dashscope_compat
      cosyvoice-v3-flash: dashscope

    # 前缀映射
    prefix_mappings:
      qwen: dashscope_compat
      gpt: openai

    # 默认供应商
    default_provider: dashscope_compat

    # 降级供应商列表（按优先级）
    fallback_providers:
      - dashscope

    # 自动重试配置
    enable_auto_retry: true
    max_retry_attempts: 3
